# ─── MySQL ───────────────────────────────
MYSQL_DB=okane_db
MYSQL_ROOT_PASSWORD=root

# ─── App ─────────────────────────────────
APP_PORT=8080
DB_PORT=3306

# ─── Spring DataSource ──────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/okane_db?useUnicode=true&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# ─── Twilio ─────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Mail ───────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=

# ─── Java ───────────────────────────────
JAVA_VERSION=21

# ─── AI / Chatbot ───────────────────────
# AI_PROVIDER: gemini | gpt | deepseek
AI_PROVIDER=gemini
# AI_API_KEY: clé API du fournisseur choisi
AI_API_KEY=
# AI_MODEL — selon fournisseur :
#   gemini   → gemini-2.0-flash, gemini-2.0-pro, gemini-1.5-pro, gemini-1.5-flash
#   gpt      → gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo
#   deepseek → deepseek-chat, deepseek-reasoner
AI_MODEL=gemini-2.0-flash
# AI_API_URL — endpoint OpenAI-compatible :
#   gemini   → https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#   gpt      → https://api.openai.com/v1/chat/completions
#   deepseek → https://api.deepseek.com/chat/completions
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
