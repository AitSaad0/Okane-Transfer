# ─── PostgreSQL ───────────────────────────────
POSTGRES_DB=           # Nom de ta base de données
POSTGRES_USER=         # Utilisateur PostgreSQL
POSTGRES_PASSWORD=     # Mot de passe PostgreSQL

# ─── App (Spring MVC) ─────────────────────────
APP_PORT=8080          # Port exposé de l'application
DB_HOST=postgres       # Nom du service DB dans docker-compose
DB_PORT=5432           # Port PostgreSQL (défaut: 5432)